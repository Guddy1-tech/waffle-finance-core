{
  "buildCommand": "pnpm install --no-frozen-lockfile && pnpm --filter @stelleth/sdk build && pnpm --filter @stelleth/frontend build && rm -rf dist && cp -r frontend/dist dist",
  "outputDirectory": "dist",
  "installCommand": "npm install -g pnpm@latest",
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "https://stelleth-k36vx.ondigitalocean.app/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
