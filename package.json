{
  "name": "stelleth",
  "version": "1.0.0",
  "description": "Stelleth — non-custodial Ethereum ↔ Stellar atomic swap bridge using HTLCs",
  "type": "module",
  "private": true,
  "workspaces": [
    "contracts",
    "relayer",
    "frontend",
    "resolver",
    "coordinator",
    "e2e",
    "packages/*"
  ],
  "packageManager": "pnpm@8.15.0",
  "scripts": {
    "start": "pnpm --filter relayer start",
    "dev": "pnpm -r dev",
    "build": "pnpm -r build",
    "build:prod": "NODE_ENV=production pnpm -r build",
    "test": "pnpm -r test",
    "test:e2e": "pnpm --filter @stelleth/e2e test",
    "lint": "pnpm -r lint",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "contracts:compile": "pnpm --filter contracts compile",
    "contracts:deploy": "pnpm --filter contracts deploy",
    "contracts:deploy:sepolia": "pnpm --filter contracts deploy:sepolia",
    "stellar:build": "pnpm --filter stellar build",
    "relayer:start": "pnpm --filter relayer start",
    "relayer:start:prod": "NODE_ENV=production pnpm --filter relayer start",
    "frontend:dev": "pnpm --filter frontend dev",
    "frontend:build": "pnpm --filter frontend build",
    "frontend:build:prod": "NODE_ENV=production pnpm --filter frontend build",
    "frontend:preview": "pnpm --filter frontend preview",
    "health:check": "curl -s http://localhost:3001/health | jq .",
    "deploy:setup": "cp .env.production .env && pnpm build:prod"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "eslint": "^8.56.0",
    "prettier": "^3.1.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/your-username/stelleth.git"
  },
  "keywords": [
    "cross-chain",
    "ethereum",
    "stellar",
    "bridge",
    "defi",
    "htlc",
    "fusion",
    "1inch",
    "ethglobal"
  ],
  "author": "Stelleth Team",
  "license": "MIT",
  "dependencies": {}
}